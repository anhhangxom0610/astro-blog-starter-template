---
import { getCollection } from 'astro:content';
import DealaBase from '../../layouts/DealaBase.astro';
import { SITE_TITLE } from '../../consts';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<DealaBase title={`${SITE_TITLE} | Blog`} description="Tong hop bai viet va cam nang mua sam.">
	<section class="section blog-hero">
		<div class="container blog-hero-inner">
			<div>
				<p class="eyebrow">Blog</p>
				<h1>Cam nang san deal va mua sam thong minh.</h1>
				<p class="lead">
					Bai viet, huong dan va xu huong uu dai moi nhat tu cac thuong hieu noi bat.
				</p>
				<div class="hero-actions">
					<a class="btn" href="/#deals">Xem deal hot</a>
					<a class="ghost" href="/#categories">Xem danh muc</a>
				</div>
			</div>
			<div class="blog-hero-card">
				<h3>Bai viet moi</h3>
				<p>
					Doc nhanh cac huong dan, review va kinh nghiem san ma giam gia cho tung danh muc.
				</p>
				<div class="chip">Cap nhat hang tuan</div>
			</div>
		</div>
	</section>

	<section class="section alt">
		<div class="container">
			<div class="section-head">
				<div>
					<p class="eyebrow">Danh sach bai viet</p>
					<h2>Goi y doc cho ban</h2>
				</div>
				<a class="ghost" href="/#blog">Quay ve trang chu</a>
			</div>
			<div class="grid blog-grid">
				{posts.map((post) => (
					<article class="blog-card">
						<a href={`/blog/${post.id}/`}>
							<img width={720} height={360} src={post.data.heroImage} alt="" />
							<div class="blog-card-body">
								<p class="chip">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</div>
						</a>
					</article>
				))}
			</div>
		</div>
	</section>
</DealaBase>

<style>
	.blog-hero-inner {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
		align-items: center;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.blog-hero-card {
		background: white;
		border-radius: 24px;
		padding: 2rem;
		box-shadow: var(--shadow);
		border: 1px solid var(--border);
		display: grid;
		gap: 1rem;
	}

	.section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 2.2rem;
	}

	.blog-grid {
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	}

	.blog-card {
		background: white;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 18px 40px rgba(12, 27, 42, 0.08);
		border: 1px solid var(--border);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.blog-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 24px 50px rgba(12, 27, 42, 0.12);
	}

	.blog-card img {
		width: 100%;
		display: block;
	}

	.blog-card-body {
		padding: 1.5rem;
		display: grid;
		gap: 0.6rem;
	}

	.blog-card h3 {
		margin: 0;
	}

	@media (max-width: 720px) {
		.section-head {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
