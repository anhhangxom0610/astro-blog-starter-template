---
import BaseHead from '../components/BaseHead.astro';

const pageTitle = 'Khuyen mai server / VPS / domain / hosting';
const pageDescription =
	'Tong hop coupon va uu dai ha tang so: server, VPS, domain va hosting voi mo ta ro rang.';

const categories = [
	{
		id: 'server',
		name: 'Server',
		summary: 'Uu dai cho server vat ly va may chu doanh nghiep.',
		items: [
			{
				provider: 'TitanRack',
				title: 'Giam 25% phi setup server moi',
				description:
					'Tang bang thong no gioi han 1 thang va ho tro chuyen doi mien phi trong 48h.',
				code: 'SETUP25',
				meta: 'Het han 30/06/2026',
				badge: 'Hot'
			},
			{
				provider: 'OVHcloud',
				title: 'Server bare metal giam 20%',
				description:
					'Tang 1 IP public va chong DDoS mac dinh, kich hoat nhanh trong 2 gio.',
				code: 'OVH20',
				meta: 'Ap dung 6 thang',
				badge: 'Pho bien'
			},
			{
				provider: 'VinaMetal',
				title: 'Server Intel Gen 4 giam 18%',
				description:
					'Bao hanh phan cung 24/7, tang them 1 IP va giam phi gia han quy 1.',
				code: 'GEN418',
				meta: 'Ap dung 12 thang',
				badge: 'New'
			}
		]
	},
	{
		id: 'vps',
		name: 'VPS',
		summary: 'VPS NVMe, cloud compute, toi uu cho developer va doanh nghiep.',
		items: [
			{
				provider: 'CloudNova',
				title: 'Giam 35% VPS NVMe 6 thang',
				description:
					'He thong tu dong sao luu hang ngay, free snapshot va nang cap RAM 2GB.',
				code: 'NVME35',
				meta: 'Chi ap dung online',
				badge: 'Hot'
			},
			{
				provider: 'DigitalOcean',
				title: 'Giam 25% droplet cho team moi',
				description:
					'Credit su dung 60 ngay, tang them 1 backup va snapshot mien phi.',
				code: 'DO25',
				meta: 'Doi moi tai khoan',
				badge: 'Hot'
			},
			{
				provider: 'SkyCompute',
				title: 'VPS khoi tao giam 20%',
				description:
					'Tang them 20% CPU burst, ho tro di chuyen du lieu mien phi.',
				code: 'START20',
				meta: 'Het han 15/05/2026',
				badge: 'Gia tot'
			}
		]
	},
	{
		id: 'domain',
		name: 'Domain',
		summary: 'Ten mien quoc te va Viet Nam, kem bao mat DNS.',
		items: [
			{
				provider: 'Namecheap',
				title: 'Giam 35% ten mien .com/.net',
				description:
					'Tang bao ve thong tin WHOIS va chuyen huong SSL 1 nam dau.',
				code: 'NC35',
				meta: 'Het han 20/04/2026',
				badge: 'Pho bien'
			},
			{
				provider: 'GoDaddy',
				title: 'Giam 30% ten mien .com moi',
				description:
					'Kem DNS quan ly, tu dong gia han va bao ve ten mien co ban.',
				code: 'GOD30',
				meta: 'Ap dung lan dau',
				badge: 'Tin cay'
			},
			{
				provider: 'VietDomain',
				title: 'Giam 30% ten mien .vn',
				description:
					'Mien phi DNSSEC va tu dong gia han khi sap het han.',
				code: 'VN30',
				meta: 'Ap dung ca doanh nghiep',
				badge: 'Tin cay'
			}
		]
	},
	{
		id: 'hosting',
		name: 'Hosting',
		summary: 'Hosting web, Wordpress, doanh nghiep voi SSL mien phi.',
		items: [
			{
				provider: 'HostWave',
				title: 'Hosting Wordpress giam 40%',
				description:
					'Tang CDN toan cau, SSL tu dong va ho tro di chuyen site.',
				code: 'WP40',
				meta: 'Nam dau tien',
				badge: 'Hot'
			},
			{
				provider: 'GoDaddy',
				title: 'Hosting co ban giam 30%',
				description:
					'Mien phi domain 1 nam va email doanh nghiep 12 thang dau.',
				code: 'GDHOST30',
				meta: 'Goi co ban',
				badge: 'Pho bien'
			},
			{
				provider: 'ResellPro',
				title: 'Reseller Hosting giam 25%',
				description:
					'Tang 10 tai khoan con va mien phi email doanh nghiep 1 nam.',
				code: 'RESELL25',
				meta: 'So luong gioi han',
				badge: 'Moi'
			}
		]
	}
];

const totalCoupons = categories.reduce((sum, category) => sum + category.items.length, 0);
const providerSet = new Set(categories.flatMap((category) => category.items.map((item) => item.provider)));
const totalProviders = providerSet.size;

const getBadge = (provider) => {
	const words = provider.split(' ').filter(Boolean);
	if (words.length === 1) {
		return provider.slice(0, 2).toUpperCase();
	}
	return words.map((word) => word[0]).join('').slice(0, 2).toUpperCase();
};
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body class="deala">
		<a class="skip-link" href="#main">Bo qua dieu huong</a>
		<div class="page">
			<header class="site-header">
				<div class="topbar">
					<div class="container topbar-inner">
						<p>Sieu uu dai hom nay: hoan tien den 40% va ma giam gia doc quyen.</p>
						<div class="topbar-actions">
							<a class="text-link" href="#app">Tai app</a>
							<a class="text-link" href="#support">Ho tro</a>
							<a class="btn small" href="#login">Dang nhap</a>
						</div>
					</div>
				</div>
				<div class="nav">
					<div class="container nav-inner">
						<a class="logo" href="/">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</a>
						<nav class="nav-links" aria-label="Chinh">
							<a href="#server">Server</a>
							<a href="#vps">VPS</a>
							<a href="#domain">Domain</a>
							<a href="#hosting">Hosting</a>
							<a href="#how">Cach su dung</a>
						</nav>
						<div class="nav-actions">
							<a class="ghost" href="#submit">Them ma giam gia</a>
							<a class="btn" href="#signup">Nhan uu dai</a>
						</div>
					</div>
				</div>
			</header>

			<main id="main">
				<section class="hero">
					<div class="container hero-grid">
						<div class="hero-copy">
							<p class="eyebrow">Ha tang so</p>
							<h1>San coupon server, VPS, domain va hosting.</h1>
							<p class="lead">
								Danh sach uu dai duoc chon loc cho ha tang so. Moi item co mo ta ro
								rang ve dieu kien va gia tri giam.
							</p>
							<form class="search" role="search">
								<label class="sr-only" for="infra-search">Tim coupon</label>
								<div class="search-input">
									<span class="search-icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<circle cx="11" cy="11" r="7"></circle>
											<path d="M20 20l-3.5-3.5"></path>
										</svg>
									</span>
									<input
										id="infra-search"
										type="text"
										placeholder="Nhap nha cung cap, ma giam gia, goi dich vu"
									/>
									<button class="btn" type="submit">Tim coupon</button>
								</div>
							</form>
							<div class="hero-stats">
								<div>
									<h3>{totalCoupons}</h3>
									<p>Coupon dang hoat dong</p>
								</div>
								<div>
									<h3>{totalProviders}</h3>
									<p>Nha cung cap</p>
								</div>
								<div>
									<h3>98%</h3>
									<p>Ti le ap dung</p>
								</div>
							</div>
							<div class="hero-actions">
								<a class="btn" href="#server">Xem coupon</a>
								<a class="ghost" href="#how">Xem huong dan</a>
							</div>
						</div>
						<div class="hero-visual">
							<div class="hero-orb"></div>
							<div class="coupon-stack">
								<div class="coupon-card reveal" style="--delay: 0.1s">
									<div class="coupon-brand">
										<span class="brand-dot"></span>
										<p>NAMECHEAP</p>
									</div>
									<h4>Giam 35% ten mien .com/.net</h4>
									<p class="coupon-meta">Bao ve WHOIS 1 nam</p>
									<div class="coupon-footer">
										<span class="tag">NEW</span>
										<button class="code">NC35</button>
									</div>
								</div>
								<div class="coupon-card highlight reveal" style="--delay: 0.25s">
									<div class="coupon-brand">
										<span class="brand-dot"></span>
										<p>DIGITALOCEAN</p>
									</div>
									<h4>Giam 25% droplet cho team moi</h4>
									<p class="coupon-meta">Credit su dung 60 ngay</p>
									<div class="coupon-footer">
										<span class="tag alt">HOT</span>
										<button class="code">DO25</button>
									</div>
								</div>
								<div class="coupon-card mini reveal" style="--delay: 0.4s">
									<p>Hosting Wordpress</p>
									<strong>Giam 40%</strong>
									<span class="chip">Nam dau tien</span>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="section" aria-labelledby="cat-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Danh muc</p>
								<h2 id="cat-title">Chon nhanh theo nhu cau ha tang</h2>
							</div>
							<a class="ghost" href="#all-categories">Xem tat ca</a>
						</div>
						<div class="grid categories-grid">
							{categories.map((category, index) => (
								<article class="category-card reveal" style={`--delay: ${0.1 + index * 0.1}s`}>
									<h3>{category.name}</h3>
									<p>{category.summary}</p>
									<p>{category.items.length} uu dai</p>
								</article>
							))}
						</div>
					</div>
				</section>

				{categories.map((category) => (
					<section class="section alt" id={category.id} aria-labelledby={`${category.id}-title`}>
						<div class="container">
							<div class="section-head">
								<div>
									<p class="eyebrow">{category.name}</p>
									<h2 id={`${category.id}-title`}>{category.summary}</h2>
								</div>
								<div class="chip-row">
									<span class="chip">Moi nhat</span>
									<span class="chip">Uu dai nhieu</span>
									<span class="chip">Gia tot</span>
								</div>
							</div>
							<div class="grid deals-grid">
								{category.items.map((item, itemIndex) => (
									<article class="deal-card reveal" style={`--delay: ${0.1 + itemIndex * 0.1}s`}>
										<div class="deal-header">
											<span class="store-badge">{getBadge(item.provider)}</span>
											<div>
												<h3>{item.provider}</h3>
												<p>{category.name}</p>
											</div>
										</div>
										<p class="deal-title">{item.title}</p>
										<p class="deal-desc">{item.description}</p>
										<div class="deal-meta">
											<span class={item.badge === 'Hot' ? 'tag alt' : 'tag'}>
												{item.badge}
											</span>
											<span class="muted">{item.meta}</span>
										</div>
										<div class="deal-footer">
											<button class="code">{item.code}</button>
											<a class="text-link" href="#">Xem chi tiet</a>
										</div>
									</article>
								))}
							</div>
						</div>
					</section>
				))}

				<section class="section" id="providers" aria-labelledby="providers-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Nha cung cap noi bat</p>
								<h2 id="providers-title">Thuong hieu ha tang duoc tim nhieu</h2>
							</div>
							<a class="ghost" href="#all-providers">Xem tat ca</a>
						</div>
						<div class="stores-row">
							{Array.from(providerSet).map((provider) => (
								<div class="store-pill">{provider}</div>
							))}
						</div>
					</div>
				</section>

				<section class="section steps" id="how" aria-labelledby="how-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Cach su dung</p>
								<h2 id="how-title">Nhan coupon ha tang trong 3 buoc</h2>
							</div>
						</div>
						<div class="grid steps-grid">
							<div class="step-card reveal" style="--delay: 0.1s">
								<span class="step">01</span>
								<h3>Chon danh muc phu hop</h3>
								<p>Loc theo server, VPS, domain hoac hosting de tim coupon nhanh.</p>
							</div>
							<div class="step-card reveal" style="--delay: 0.2s">
								<span class="step">02</span>
								<h3>Doc ky mo ta</h3>
								<p>Moi coupon co dieu kien su dung, thoi gian va gia tri giam ro rang.</p>
							</div>
							<div class="step-card reveal" style="--delay: 0.3s">
								<span class="step">03</span>
								<h3>Ap dung luc thanh toan</h3>
								<p>Nhap ma khi dang ky dich vu de nhan giam gia ngay.</p>
							</div>
						</div>
					</div>
				</section>

				<section class="section app" id="app" aria-labelledby="app-title">
					<div class="container app-inner">
						<div>
							<p class="eyebrow">Ung dung di dong</p>
							<h2 id="app-title">Nhan thong bao coupon ha tang moi</h2>
							<p class="lead">
								Luu coupon, theo doi nha cung cap va nhan thong bao khi co uu dai moi.
							</p>
							<div class="app-actions">
								<a class="btn" href="#">Tai tren App Store</a>
								<a class="ghost" href="#">Tai tren Google Play</a>
							</div>
						</div>
						<div class="app-card">
							<div class="app-screen">
								<div class="screen-header">
									<span></span>
									<span></span>
									<span></span>
								</div>
								<div class="screen-body">
									<h4>Coupon ha tang noi bat</h4>
									<div class="screen-item"></div>
									<div class="screen-item"></div>
									<div class="screen-item"></div>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="section newsletter" id="signup" aria-labelledby="news-title">
					<div class="container newsletter-inner">
						<div>
							<p class="eyebrow">Ban tin ha tang</p>
							<h2 id="news-title">Nhan thong tin coupon moi moi ngay</h2>
							<p class="lead">Cap nhat uu dai tu nha cung cap server, VPS va hosting.</p>
						</div>
						<form class="newsletter-form">
							<label class="sr-only" for="newsletter-email">Email</label>
							<input id="newsletter-email" type="email" placeholder="Nhap email cua ban" />
							<button class="btn" type="submit">Dang ky</button>
						</form>
					</div>
				</section>
			</main>

			<footer class="site-footer" id="support">
				<div class="container footer-grid">
					<div>
						<div class="logo footer-logo">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</div>
						<p>Kenh san coupon ha tang so cho cong dong developer va doanh nghiep.</p>
					</div>
					<div>
						<h4>Ve Deala</h4>
						<a href="#">Gioi thieu</a>
						<a href="#">Doi tac</a>
						<a href="#">Tuyen dung</a>
					</div>
					<div>
						<h4>Ho tro</h4>
						<a href="#">Trung tam tro giup</a>
						<a href="#">Dieu khoan</a>
						<a href="#">Bao mat</a>
					</div>
					<div>
						<h4>Theo doi</h4>
						<a href="#">Facebook</a>
						<a href="#">Instagram</a>
						<a href="#">TikTok</a>
					</div>
				</div>
				<div class="footer-bottom">
					<p>&copy; 2026 Deala. All rights reserved.</p>
					<div class="footer-badges">
						<span>SSL Secure</span>
						<span>Trusted Providers</span>
						<span>24/7 Support</span>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700&display=swap');

	:global(body.deala) {
		--ink: #0c1b2a;
		--muted: #5b6b7f;
		--brand: #ff7a45;
		--brand-strong: #ff5c1f;
		--brand-soft: #ffd7c6;
		--accent: #1fc7a6;
		--accent-dark: #0f8f77;
		--card: #ffffff;
		--border: rgba(12, 27, 42, 0.08);
		--shadow: 0 24px 60px rgba(12, 27, 42, 0.18);
		font-family: 'Manrope', 'Segoe UI', sans-serif;
		background: radial-gradient(circle at 10% 10%, #fff4ee 0%, transparent 45%),
			radial-gradient(circle at 90% 0%, #e7fbf6 0%, transparent 40%),
			linear-gradient(180deg, #fff8f2 0%, #ffffff 60%, #f6f9ff 100%);
		color: var(--ink);
		margin: 0;
	}

	:global(body.deala) main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	:global(body.deala) h1,
	:global(body.deala) h2,
	:global(body.deala) h3,
	:global(body.deala) h4 {
		font-family: 'Sora', 'Segoe UI', sans-serif;
		color: var(--ink);
		margin: 0 0 0.8rem 0;
	}

	:global(body.deala) p {
		margin: 0;
		color: var(--muted);
	}

	:global(body.deala) a {
		color: inherit;
		text-decoration: none;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.container {
		width: min(1200px, calc(100% - 2.5rem));
		margin: 0 auto;
	}

	.skip-link {
		position: absolute;
		left: -999px;
		top: 0;
		padding: 0.6rem 1rem;
		background: #fff;
		color: var(--ink);
		border-radius: 999px;
		z-index: 50;
	}
	.skip-link:focus {
		left: 1rem;
		top: 1rem;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(16px);
		background: rgba(255, 255, 255, 0.85);
		border-bottom: 1px solid var(--border);
	}

	.topbar {
		background: linear-gradient(90deg, #0f1e2f, #1b2d42);
		color: #eaf2ff;
		font-size: 0.9rem;
	}

	.topbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.6rem 0;
	}

	.topbar p {
		color: #eaf2ff;
		font-weight: 500;
	}

	.topbar-actions {
		display: flex;
		gap: 0.8rem;
		align-items: center;
	}

	.nav {
		padding: 0.8rem 0;
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.2rem;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-family: 'Sora', 'Segoe UI', sans-serif;
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--ink);
	}

	.logo-mark {
		width: 32px;
		height: 32px;
		border-radius: 12px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--brand), var(--accent));
		color: white;
		font-weight: 700;
	}

	.logo-plus {
		color: var(--brand);
	}

	.nav-links {
		display: flex;
		gap: 1.2rem;
		font-weight: 500;
		color: var(--muted);
	}

	.nav-links a:hover {
		color: var(--ink);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.ghost,
	.text-link {
		border: 1px solid transparent;
		padding: 0.5rem 1.1rem;
		border-radius: 999px;
		font-weight: 600;
		color: var(--muted);
		background: transparent;
		transition: all 0.2s ease;
	}

	.text-link {
		padding: 0.4rem 0.4rem;
	}

	.ghost:hover {
		border-color: var(--border);
		color: var(--ink);
		background: rgba(255, 122, 69, 0.08);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border: none;
		padding: 0.65rem 1.5rem;
		border-radius: 999px;
		background: linear-gradient(135deg, var(--brand), var(--brand-strong));
		color: white;
		font-weight: 600;
		box-shadow: 0 12px 24px rgba(255, 92, 31, 0.25);
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 30px rgba(255, 92, 31, 0.3);
	}

	.btn.small {
		padding: 0.4rem 1rem;
		font-size: 0.9rem;
		box-shadow: none;
	}

	.hero {
		padding: 4.5rem 0 3.5rem;
