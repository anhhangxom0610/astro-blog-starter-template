---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="deala">
		<a class="skip-link" href="#main">Bỏ qua điều hướng</a>
		<div class="page">
			<header class="site-header">
				<div class="topbar">
					<div class="container topbar-inner">
						<p>Siêu ưu đãi hôm nay: hoàn tiền đến 40% và mã giảm giá độc quyền.</p>
						<div class="topbar-actions">
							<a class="text-link" href="#app">Tải app</a>
							<a class="text-link" href="#support">Hỗ trợ</a>
							<a class="btn small" href="#login">Đăng nhập</a>
						</div>
					</div>
				</div>
				<div class="nav">
					<div class="container nav-inner">
						<a class="logo" href="/">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</a>
						<nav class="nav-links" aria-label="Chinh">
							<a href="#deals">Deal nổi bật</a>
							<a href="#categories">Danh mục</a>
							<a href="#stores">Cua hang</a>
							<a href="#how">Cach hoat dong</a>
							<a href="#blog">Cam nang</a>
						</nav>
						<div class="nav-actions">
							<a class="ghost" href="#submit">Them ma giam gia</a>
							<a class="btn" href="#signup">Nhan uu dai</a>
						</div>
					</div>
				</div>
			</header>

			<main id="main">
				<section class="hero">
					<div class="container hero-grid">
						<div class="hero-copy">
							<p class="eyebrow">Nen tang san deal thong minh</p>
							<h1>
								San ma giam gia va uu dai chat luong cho moi nhu cau mua sam.
							</h1>
							<p class="lead">
								Tim kiem hon 12.000 ma giam gia, hoan tien va deal theo khu vuc. Cap nhat lien tuc
								de ban khong bo lo uu dai moi.
							</p>
							<form class="search" role="search">
								<label class="sr-only" for="deal-search">Tim deal</label>
								<div class="search-input">
									<span class="search-icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<circle cx="11" cy="11" r="7"></circle>
											<path d="M20 20l-3.5-3.5"></path>
										</svg>
									</span>
									<input
										id="deal-search"
										type="text"
										placeholder="Nhap ten cua hang, ma giam gia, san pham"
									/>
									<button class="btn" type="submit">Tim deal</button>
								</div>
							</form>
							<div class="hero-stats">
								<div>
									<h3>12K+</h3>
									<p>Ma giam gia</p>
								</div>
								<div>
									<h3>1.8K</h3>
									<p>Cua hang doi tac</p>
								</div>
								<div>
									<h3>98%</h3>
									<p>Ti le thanh cong</p>
								</div>
							</div>
							<div class="hero-actions">
								<a class="btn" href="#deals">Xem deal hot</a>
								<a class="ghost" href="#how">Xem huong dan</a>
							</div>
						</div>
						<div class="hero-visual">
							<div class="hero-orb"></div>
							<div class="coupon-stack">
								<div class="coupon-card reveal" style="--delay: 0.1s">
									<div class="coupon-brand">
										<span class="brand-dot"></span>
										<p>FRESH MART</p>
									</div>
									<h4>Giam 30% cho don hang tren 500K</h4>
									<p class="coupon-meta">Het han: 30/04/2026</p>
									<div class="coupon-footer">
										<span class="tag">NEW</span>
										<button class="code">FRESH30</button>
									</div>
								</div>
								<div class="coupon-card highlight reveal" style="--delay: 0.25s">
									<div class="coupon-brand">
										<span class="brand-dot"></span>
										<p>TRAVEL GO</p>
									</div>
									<h4>Hoan tien 18% cho tour he</h4>
									<p class="coupon-meta">Ap dung toan quoc</p>
									<div class="coupon-footer">
										<span class="tag alt">HOT</span>
										<button class="code">SUMMER18</button>
									</div>
								</div>
								<div class="coupon-card mini reveal" style="--delay: 0.4s">
									<p>Flash Sale 2 gio</p>
									<strong>Giam 120K</strong>
									<span class="chip">Chi hom nay</span>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="section" id="categories" aria-labelledby="cat-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Danh muc pho bien</p>
								<h2 id="cat-title">De dang tim deal theo nhu cau</h2>
							</div>
							<a class="ghost" href="#all-categories">Xem tat ca</a>
						</div>
						<div class="grid categories-grid">
							<article class="category-card reveal" style="--delay: 0.1s">
								<div class="icon peach">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M4 7h16l-1.5 12.5H5.5L4 7z"></path>
										<path d="M9 7V5a3 3 0 0 1 6 0v2"></path>
									</svg>
								</div>
								<h3>Mua sam</h3>
								<p>1.2K uu dai</p>
							</article>
							<article class="category-card reveal" style="--delay: 0.2s">
								<div class="icon mint">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M4 12h16"></path>
										<path d="M7 5c4 2 6 2 10 0 0 6-2 10-5 14-3-4-5-8-5-14z"></path>
									</svg>
								</div>
								<h3>An uong</h3>
								<p>860 uu dai</p>
							</article>
							<article class="category-card reveal" style="--delay: 0.3s">
								<div class="icon sky">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M3 12h18"></path>
										<path d="M7 12l10-7v14l-10-7z"></path>
									</svg>
								</div>
								<h3>Giai tri</h3>
								<p>540 uu dai</p>
							</article>
							<article class="category-card reveal" style="--delay: 0.4s">
								<div class="icon lavender">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M6 4h12l-1 16H7L6 4z"></path>
										<path d="M9 4V3h6v1"></path>
									</svg>
								</div>
								<h3>My pham</h3>
								<p>430 uu dai</p>
							</article>
							<article class="category-card reveal" style="--delay: 0.5s">
								<div class="icon lemon">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M5 9h14l-1.2 9H6.2L5 9z"></path>
										<path d="M9 9V5h6v4"></path>
									</svg>
								</div>
								<h3>Thoi trang</h3>
								<p>1.1K uu dai</p>
							</article>
							<article class="category-card reveal" style="--delay: 0.6s">
								<div class="icon coral">
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M4 12c4-6 12-6 16 0"></path>
										<path d="M6 15c3-4 9-4 12 0"></path>
									</svg>
								</div>
								<h3>Du lich</h3>
								<p>620 uu dai</p>
							</article>
						</div>
					</div>
				</section>

				<section class="section alt" id="deals" aria-labelledby="deals-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Deal noi bat</p>
								<h2 id="deals-title">Uu dai duoc san trong 24h</h2>
							</div>
							<div class="chip-row">
								<span class="chip">Tat ca</span>
								<span class="chip">Hoan tien</span>
								<span class="chip">Mien phi van chuyen</span>
								<span class="chip">Flash sale</span>
							</div>
						</div>
						<div class="grid deals-grid">
							<article class="deal-card reveal" style="--delay: 0.1s">
								<div class="deal-header">
									<span class="store-badge">FM</span>
									<div>
										<h3>Fresh Mart</h3>
										<p>Do gia dung</p>
									</div>
								</div>
								<p class="deal-title">Giam 25% + tang voucher 50K</p>
								<div class="deal-meta">
									<span class="tag">Con 2 ngay</span>
									<span class="muted">Ap dung online</span>
								</div>
								<div class="deal-footer">
									<button class="code">SAVE25</button>
									<a class="text-link" href="#">Xem chi tiet</a>
								</div>
							</article>
							<article class="deal-card reveal" style="--delay: 0.2s">
								<div class="deal-header">
									<span class="store-badge">TG</span>
									<div>
										<h3>Travel Go</h3>
										<p>Tour he 2026</p>
									</div>
								</div>
								<p class="deal-title">Hoan tien 18% cho ve may bay</p>
								<div class="deal-meta">
									<span class="tag alt">Hot</span>
									<span class="muted">Mien phi doi ve</span>
								</div>
								<div class="deal-footer">
									<button class="code">FLY18</button>
									<a class="text-link" href="#">Xem chi tiet</a>
								</div>
							</article>
							<article class="deal-card reveal" style="--delay: 0.3s">
								<div class="deal-header">
									<span class="store-badge">GF</span>
									<div>
										<h3>Green Food</h3>
										<p>Thuc pham tuoi</p>
									</div>
								</div>
								<p class="deal-title">Mien phi van chuyen cho don 299K</p>
								<div class="deal-meta">
									<span class="tag">New</span>
									<span class="muted">Ap dung toan quoc</span>
								</div>
								<div class="deal-footer">
									<button class="code">SHIP0</button>
									<a class="text-link" href="#">Xem chi tiet</a>
								</div>
							</article>
							<article class="deal-card reveal" style="--delay: 0.4s">
								<div class="deal-header">
									<span class="store-badge">BT</span>
									<div>
										<h3>Beauty Time</h3>
										<p>Lam dep</p>
									</div>
								</div>
								<p class="deal-title">Giam 120K cho combo cham soc da</p>
								<div class="deal-meta">
									<span class="tag">Con 12h</span>
									<span class="muted">Mua tai cua hang</span>
								</div>
								<div class="deal-footer">
									<button class="code">SKIN120</button>
									<a class="text-link" href="#">Xem chi tiet</a>
								</div>
							</article>
							<article class="deal-card reveal" style="--delay: 0.5s">
								<div class="deal-header">
									<span class="store-badge">FD</span>
									<div>
										<h3>Fun Digital</h3>
										<p>Giai tri so</p>
									</div>
								</div>
								<p class="deal-title">Mua 1 tang 1 goi goi phim 12 thang</p>
								<div class="deal-meta">
									<span class="tag alt">Hot</span>
									<span class="muted">Kich hoat online</span>
								</div>
								<div class="deal-footer">
									<button class="code">MOVIE11</button>
									<a class="text-link" href="#">Xem chi tiet</a>
								</div>
							</article>
							<article class="deal-card reveal" style="--delay: 0.6s">
								<div class="deal-header">
									<span class="store-badge">HT</span>
									<div>
										<h3>Home Tech</h3>
										<p>Do gia dung thong minh</p>
									</div>
								</div>
								<p class="deal-title">Giam 15% cho thiet bi nha bep</p>
								<div class="deal-meta">
									<span class="tag">New</span>
									<span class="muted">So luong gioi han</span>
								</div>
								<div class="deal-footer">
									<button class="code">SMART15</button>
									<a class="text-link" href="#">Xem chi tiet</a>
								</div>
							</article>
						</div>
					</div>
				</section>

				<section class="section" id="stores" aria-labelledby="stores-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Thuong hieu noi bat</p>
								<h2 id="stores-title">Cua hang duoc san nhieu nhat</h2>
							</div>
							<a class="ghost" href="#all-stores">Xem them cua hang</a>
						</div>
						<div class="stores-row">
							<div class="store-pill">Glowmart</div>
							<div class="store-pill">Pizza Home</div>
							<div class="store-pill">Urban Wear</div>
							<div class="store-pill">Wellness+ Spa</div>
							<div class="store-pill">Aqua Sport</div>
							<div class="store-pill">Booky</div>
							<div class="store-pill">Dream Travel</div>
							<div class="store-pill">City Mart</div>
						</div>
					</div>
				</section>

				<section class="section steps" id="how" aria-labelledby="how-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Cach hoat dong</p>
								<h2 id="how-title">Nhan ma giam gia trong 3 buoc</h2>
							</div>
						</div>
						<div class="grid steps-grid">
							<div class="step-card reveal" style="--delay: 0.1s">
								<span class="step">01</span>
								<h3>Tim deal phu hop</h3>
								<p>Loc theo danh muc, khu vuc va thuong hieu yeu thich.</p>
							</div>
							<div class="step-card reveal" style="--delay: 0.2s">
								<span class="step">02</span>
								<h3>Lay ma giam gia</h3>
								<p>Chi mot nhap chuot, ma se duoc sao chep tu dong.</p>
							</div>
							<div class="step-card reveal" style="--delay: 0.3s">
								<span class="step">03</span>
								<h3>Ap dung khi thanh toan</h3>
								<p>Su dung ma de giam gia ngay tai trang thanh toan.</p>
							</div>
						</div>
					</div>
				</section>

				<section class="section app" id="app" aria-labelledby="app-title">
					<div class="container app-inner">
						<div>
							<p class="eyebrow">Ung dung di dong</p>
							<h2 id="app-title">Nhan thong bao deal moi moi ngay</h2>
							<p class="lead">
								Luu deal, theo doi cua hang va nhan thong bao flash sale theo khu vuc.
							</p>
							<div class="app-actions">
								<a class="btn" href="#">Tai tren App Store</a>
								<a class="ghost" href="#">Tai tren Google Play</a>
							</div>
						</div>
						<div class="app-card">
							<div class="app-screen">
								<div class="screen-header">
									<span></span>
									<span></span>
									<span></span>
								</div>
								<div class="screen-body">
									<h4>Deal gan ban</h4>
									<div class="screen-item"></div>
									<div class="screen-item"></div>
									<div class="screen-item"></div>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="section newsletter" id="blog" aria-labelledby="news-title">
					<div class="container newsletter-inner">
						<div>
							<p class="eyebrow">Ban tin Deala</p>
							<h2 id="news-title">Nhan thong tin khuyen mai va cam nang mua sam</h2>
							<p class="lead">Cap nhat moi tu doi tac va goi y deal phu hop theo so thich.</p>
						</div>
						<form class="newsletter-form">
							<label class="sr-only" for="newsletter-email">Email</label>
							<input id="newsletter-email" type="email" placeholder="Nhap email cua ban" />
							<button class="btn" type="submit">Dang ky</button>
						</form>
					</div>
				</section>
			</main>

			<footer class="site-footer" id="support">
				<div class="container footer-grid">
					<div>
						<div class="logo footer-logo">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</div>
						<p>Kenh san deal va ma giam gia thong minh cho nguoi Viet.</p>
					</div>
					<div>
						<h4>Ve Deala</h4>
						<a href="#">Gioi thieu</a>
						<a href="#">Doi tac</a>
						<a href="#">Tuyen dung</a>
					</div>
					<div>
						<h4>Ho tro</h4>
						<a href="#">Trung tam tro giup</a>
						<a href="#">Dieu khoan</a>
						<a href="#">Bao mat</a>
					</div>
					<div>
						<h4>Theo doi</h4>
						<a href="#">Facebook</a>
						<a href="#">Instagram</a>
						<a href="#">TikTok</a>
					</div>
				</div>
				<div class="footer-bottom">
					<p>&copy; 2026 Deala. All rights reserved.</p>
					<div class="footer-badges">
						<span>SSL Secure</span>
						<span>Trusted Stores</span>
						<span>24/7 Support</span>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700&display=swap');

	:global(body.deala) {
		--ink: #0c1b2a;
		--muted: #5b6b7f;
		--brand: #ff7a45;
		--brand-strong: #ff5c1f;
		--brand-soft: #ffd7c6;
		--accent: #1fc7a6;
		--accent-dark: #0f8f77;
		--card: #ffffff;
		--border: rgba(12, 27, 42, 0.08);
		--shadow: 0 24px 60px rgba(12, 27, 42, 0.18);
		font-family: 'Manrope', 'Segoe UI', sans-serif;
		background: radial-gradient(circle at 10% 10%, #fff4ee 0%, transparent 45%),
			radial-gradient(circle at 90% 0%, #e7fbf6 0%, transparent 40%),
			linear-gradient(180deg, #fff8f2 0%, #ffffff 60%, #f6f9ff 100%);
		color: var(--ink);
		margin: 0;
	}

	:global(body.deala) main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	:global(body.deala) h1,
	:global(body.deala) h2,
	:global(body.deala) h3,
	:global(body.deala) h4 {
		font-family: 'Sora', 'Segoe UI', sans-serif;
		color: var(--ink);
		margin: 0 0 0.8rem 0;
	}

	:global(body.deala) p {
		margin: 0;
		color: var(--muted);
	}

	:global(body.deala) a {
		color: inherit;
		text-decoration: none;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.container {
		width: min(1200px, calc(100% - 2.5rem));
		margin: 0 auto;
	}

	.skip-link {
		position: absolute;
		left: -999px;
		top: 0;
		padding: 0.6rem 1rem;
		background: #fff;
		color: var(--ink);
		border-radius: 999px;
		z-index: 50;
	}
	.skip-link:focus {
		left: 1rem;
		top: 1rem;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(16px);
		background: rgba(255, 255, 255, 0.85);
		border-bottom: 1px solid var(--border);
	}

	.topbar {
		background: linear-gradient(90deg, #0f1e2f, #1b2d42);
		color: #eaf2ff;
		font-size: 0.9rem;
	}

	.topbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.6rem 0;
	}

	.topbar p {
		color: #eaf2ff;
		font-weight: 500;
	}

	.topbar-actions {
		display: flex;
		gap: 0.8rem;
		align-items: center;
	}

	.nav {
		padding: 0.8rem 0;
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.2rem;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-family: 'Sora', 'Segoe UI', sans-serif;
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--ink);
	}

	.logo-mark {
		width: 32px;
		height: 32px;
		border-radius: 12px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--brand), var(--accent));
		color: white;
		font-weight: 700;
	}

	.logo-plus {
		color: var(--brand);
	}

	.nav-links {
		display: flex;
		gap: 1.2rem;
		font-weight: 500;
		color: var(--muted);
	}

	.nav-links a:hover {
		color: var(--ink);
	}

