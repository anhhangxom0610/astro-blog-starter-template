---
import DealaBase from './DealaBase.astro';
import FormattedDate from '../components/FormattedDate.astro';

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<DealaBase title={title} description={description}>
	<section class="section blog-hero">
		<div class="container blog-hero-inner">
			<div class="blog-title">
				<p class="eyebrow">Bai viet</p>
				<h1>{title}</h1>
				{description && <p class="lead">{description}</p>}
				<div class="blog-meta">
					<span class="chip">
						Ngay dang: <FormattedDate date={pubDate} />
					</span>
					{updatedDate && (
						<span class="chip">
							Cap nhat: <FormattedDate date={updatedDate} />
						</span>
					)}
				</div>
			</div>
			{heroImage && (
				<div class="blog-image">
					<img width={1200} height={600} src={heroImage} alt="" />
				</div>
			)}
		</div>
	</section>

	<section class="section blog-body">
		<div class="container blog-prose">
			<slot />
		</div>
	</section>
</DealaBase>

<style>
	.blog-hero {
		padding-top: 4.5rem;
	}

	.blog-hero-inner {
		display: grid;
		gap: 2rem;
	}

	.blog-title {
		max-width: 760px;
	}

	.blog-meta {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.blog-image img {
		width: 100%;
		display: block;
		border-radius: 24px;
		box-shadow: var(--shadow);
	}

	.blog-prose {
		max-width: 760px;
	}

	.blog-prose :global(h2) {
		font-size: 1.8rem;
		margin-top: 2rem;
	}

	.blog-prose :global(h3) {
		font-size: 1.4rem;
		margin-top: 1.6rem;
	}

	.blog-prose :global(p) {
		margin: 0 0 1.2rem 0;
		line-height: 1.8;
	}

	.blog-prose :global(ul),
	.blog-prose :global(ol) {
		margin: 0 0 1.2rem 1.2rem;
		color: var(--muted);
	}

	.blog-prose :global(li) {
		margin-bottom: 0.6rem;
	}

	.blog-prose :global(blockquote) {
		margin: 1.6rem 0;
		padding: 1rem 1.4rem;
		border-left: 4px solid var(--brand);
		background: rgba(249, 78, 48, 0.08);
		border-radius: 12px;
	}

	.blog-prose :global(code) {
		padding: 0.15rem 0.35rem;
		background: rgba(12, 27, 42, 0.08);
		border-radius: 6px;
	}

	.blog-prose :global(pre) {
		background: #0f1e2f;
		color: #eaf2ff;
		padding: 1.2rem;
		border-radius: 16px;
		overflow-x: auto;
	}
</style>
