---
import BaseHead from '../components/BaseHead.astro';

const {
	title,
	description,
	topbarMessage = 'Sieu uu dai hom nay: hoan tien den 40% va ma giam gia doc quyen.',
	navLinks,
	footerDescription = 'Kenh san deal va ma giam gia thong minh cho nguoi Viet.'
} = Astro.props;

const defaultNavLinks = [
	{ href: '/#deals', label: 'Deal noi bat' },
	{ href: '/#categories', label: 'Danh muc' },
	{ href: '/#stores', label: 'Cua hang' },
	{ href: '/#how', label: 'Cach hoat dong' },
	{ href: '/#blog', label: 'Cam nang' },
	{ href: '/khuyen-mai-ha-tang', label: 'Khuyen mai ha tang' },
	{ href: '/an-uong-cafe', label: 'An uong/Cafe' },
	{ href: '/giai-tri-phim-anh-ca-nhac', label: 'Giai tri' },
	{ href: '/du-lich', label: 'Du lich' },
	{ href: '/game-dich-vu-online', label: 'Game/Online' },
	{ href: '/giao-duc-sach-vo', label: 'Giao duc/Sach' },
	{ href: '/dich-vu-khac', label: 'Dich vu khac' },
	{ href: '/blog', label: 'Blog' }
];

const links = navLinks ?? defaultNavLinks;
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="deala">
		<a class="skip-link" href="#main">Bo qua dieu huong</a>
		<div class="page">
			<header class="site-header">
				<div class="topbar">
					<div class="container topbar-inner">
						<p>{topbarMessage}</p>
						<div class="topbar-actions">
							<a class="text-link" href="#app">Tai app</a>
							<a class="text-link" href="#support">Ho tro</a>
							<a class="btn small" href="#login">Dang nhap</a>
						</div>
					</div>
				</div>
				<div class="nav">
					<div class="container nav-inner">
						<a class="logo" href="/">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</a>
						<nav class="nav-links" aria-label="Chinh">
							{links.map((link) => (
								<a href={link.href}>{link.label}</a>
							))}
						</nav>
						<div class="nav-actions">
							<a class="ghost" href="/#submit">Them ma giam gia</a>
							<a class="btn" href="/#signup">Nhan uu dai</a>
						</div>
					</div>
				</div>
			</header>

			<main id="main">
				<slot />
			</main>

			<footer class="site-footer" id="support">
				<div class="container footer-grid">
					<div>
						<div class="logo footer-logo">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</div>
						<p>{footerDescription}</p>
					</div>
					<div>
						<h4>Ve Deala</h4>
						<a href="#">Gioi thieu</a>
						<a href="#">Doi tac</a>
						<a href="#">Tuyen dung</a>
					</div>
					<div>
						<h4>Ho tro</h4>
						<a href="#">Trung tam tro giup</a>
						<a href="#">Dieu khoan</a>
						<a href="#">Bao mat</a>
					</div>
					<div>
						<h4>Theo doi</h4>
						<a href="#">Facebook</a>
						<a href="#">Instagram</a>
						<a href="#">TikTok</a>
					</div>
				</div>
				<div class="footer-bottom">
					<p>&copy; 2026 Deala. All rights reserved.</p>
					<div class="footer-badges">
						<span>SSL Secure</span>
						<span>Trusted Stores</span>
						<span>24/7 Support</span>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700&display=swap');

	:global(body.deala) {
		--ink: #0c1b2a;
		--muted: #5b6b7f;
		--brand: #f94e30;
		--brand-strong: #f94e30;
		--brand-soft: #ffd7cf;
		--accent: #1fc7a6;
		--accent-dark: #0f8f77;
		--card: #ffffff;
		--border: rgba(12, 27, 42, 0.08);
		--shadow: 0 24px 60px rgba(12, 27, 42, 0.18);
		font-family: 'Manrope', 'Segoe UI', sans-serif;
		background: radial-gradient(circle at 10% 10%, #fff4ee 0%, transparent 45%),
			radial-gradient(circle at 90% 0%, #e7fbf6 0%, transparent 40%),
			linear-gradient(180deg, #fff8f2 0%, #ffffff 60%, #f6f9ff 100%);
		color: var(--ink);
		margin: 0;
	}

	:global(body.deala) main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	:global(body.deala) h1,
	:global(body.deala) h2,
	:global(body.deala) h3,
	:global(body.deala) h4 {
		font-family: 'Sora', 'Segoe UI', sans-serif;
		color: var(--ink);
		margin: 0 0 0.8rem 0;
	}

	:global(body.deala) p {
		margin: 0;
		color: var(--muted);
	}

	:global(body.deala) a {
		color: inherit;
		text-decoration: none;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.container {
		width: min(1200px, calc(100% - 2.5rem));
		margin: 0 auto;
	}

	.skip-link {
		position: absolute;
		left: -999px;
		top: 0;
		padding: 0.6rem 1rem;
		background: #fff;
		color: var(--ink);
		border-radius: 999px;
		z-index: 50;
	}
	.skip-link:focus {
		left: 1rem;
		top: 1rem;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(16px);
		background: rgba(255, 255, 255, 0.85);
		border-bottom: 1px solid var(--border);
	}

	.topbar {
		background: linear-gradient(90deg, #0f1e2f, #1b2d42);
		color: #eaf2ff;
		font-size: 0.9rem;
	}

	.topbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.6rem 0;
	}

	.topbar p {
		color: #eaf2ff;
		font-weight: 500;
	}

	.topbar-actions {
		display: flex;
		gap: 0.8rem;
		align-items: center;
	}

	.nav {
		padding: 0.8rem 0;
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.2rem;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-family: 'Sora', 'Segoe UI', sans-serif;
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--ink);
	}

	.logo-mark {
		width: 32px;
		height: 32px;
		border-radius: 12px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--brand), var(--accent));
		color: white;
		font-weight: 700;
	}

	.logo-plus {
		color: var(--brand);
	}

	.nav-links {
		display: flex;
		gap: 1.2rem;
		font-weight: 500;
		color: var(--muted);
		flex-wrap: wrap;
	}

	.nav-links a:hover {
		color: var(--ink);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.ghost,
	.text-link {
		border: 1px solid transparent;
		padding: 0.5rem 1.1rem;
		border-radius: 999px;
		font-weight: 600;
		color: var(--muted);
		background: transparent;
		transition: all 0.2s ease;
	}

	.text-link {
		padding: 0.4rem 0.4rem;
	}

	.ghost:hover {
		border-color: var(--border);
		color: var(--ink);
		background: rgba(249, 78, 48, 0.08);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border: none;
		padding: 0.65rem 1.5rem;
		border-radius: 999px;
		background: linear-gradient(135deg, var(--brand), var(--brand-strong));
		color: white;
		font-weight: 600;
		box-shadow: 0 12px 24px rgba(249, 78, 48, 0.25);
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 30px rgba(249, 78, 48, 0.3);
	}

	.btn.small {
		padding: 0.4rem 1rem;
		font-size: 0.9rem;
		box-shadow: none;
	}

	.section {
		padding: 3.5rem 0;
	}

	.section.alt {
		background: #f8fafc;
	}

	.grid {
		display: grid;
		gap: 1.5rem;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--accent-dark);
	}

	.lead {
		font-size: 1.05rem;
		margin-bottom: 1.5rem;
	}

	.chip {
		background: rgba(12, 27, 42, 0.06);
		color: var(--muted);
		padding: 0.3rem 0.8rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 600;
	}

	.tag {
		background: rgba(31, 199, 166, 0.15);
		color: var(--accent-dark);
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.tag.alt {
		background: rgba(249, 78, 48, 0.15);
		color: var(--brand-strong);
	}

	.code {
		background: rgba(12, 27, 42, 0.06);
		border: 1px dashed rgba(12, 27, 42, 0.2);
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		font-weight: 600;
		color: var(--ink);
		cursor: pointer;
	}

	.muted {
		color: var(--muted);
		font-size: 0.9rem;
	}

	.stores-row {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.store-pill {
		padding: 0.5rem 1.2rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: white;
		font-weight: 600;
		color: var(--ink);
		box-shadow: 0 12px 24px rgba(12, 27, 42, 0.06);
	}

	.site-footer {
		margin-top: auto;
		padding: 3.5rem 0 2rem;
		background: #0f1e2f;
		color: #e6efff;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 2rem;
	}

	.footer-grid h4 {
		color: white;
		margin-bottom: 1rem;
	}

	.footer-grid a {
		display: block;
		color: #c5d4ea;
		margin-bottom: 0.6rem;
		font-weight: 500;
	}

	.footer-logo {
		margin-bottom: 1rem;
		color: white;
	}

	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		margin-top: 2rem;
		padding-top: 1.5rem;
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
		font-size: 0.9rem;
	}

	.footer-badges {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.footer-badges span {
		padding: 0.25rem 0.8rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.12);
	}

	@media (max-width: 960px) {
		.nav-links {
			display: none;
		}
		.topbar-inner {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@media (max-width: 720px) {
		.topbar-actions {
			flex-wrap: wrap;
		}
		.nav-inner {
			flex-direction: column;
			align-items: flex-start;
		}
		.container {
			width: min(100%, calc(100% - 2rem));
		}
	}
</style>
