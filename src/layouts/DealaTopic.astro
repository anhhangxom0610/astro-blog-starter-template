---
import BaseHead from '../components/BaseHead.astro';

const {
	title,
	description,
	topbarMessage = 'Sieu uu dai hom nay: hoan tien den 40% va ma giam gia doc quyen.',
	heroEyebrow,
	heroTitle,
	heroLead,
	searchPlaceholder,
	stats = [],
	heroCards = [],
	categories = [],
	deals = [],
	stores = [],
	steps = [],
	newsletterTitle,
	newsletterLead
} = Astro.props;

const getBadge = (name) => {
	const words = name.split(' ').filter(Boolean);
	if (words.length === 1) {
		return name.slice(0, 2).toUpperCase();
	}
	return words.map((word) => word[0]).join('').slice(0, 2).toUpperCase();
};
---

<!doctype html>
<html lang="vi">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="deala">
		<a class="skip-link" href="#main">Bo qua dieu huong</a>
		<div class="page">
			<header class="site-header">
				<div class="topbar">
					<div class="container topbar-inner">
						<p>{topbarMessage}</p>
						<div class="topbar-actions">
							<a class="text-link" href="#app">Tai app</a>
							<a class="text-link" href="#support">Ho tro</a>
							<a class="btn small" href="#login">Dang nhap</a>
						</div>
					</div>
				</div>
				<div class="nav">
					<div class="container nav-inner">
						<a class="logo" href="/">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</a>
						<nav class="nav-links" aria-label="Chinh">
							<a href="#deals">Deal noi bat</a>
							<a href="#categories">Danh muc</a>
							<a href="#stores">Cua hang</a>
							<a href="#how">Cach hoat dong</a>
							<a href="#blog">Cam nang</a>
						</nav>
						<div class="nav-actions">
							<a class="ghost" href="#submit">Them ma giam gia</a>
							<a class="btn" href="#signup">Nhan uu dai</a>
						</div>
					</div>
				</div>
			</header>

			<main id="main">
				<section class="hero">
					<div class="container hero-grid">
						<div class="hero-copy">
							<p class="eyebrow">{heroEyebrow}</p>
							<h1>{heroTitle}</h1>
							<p class="lead">{heroLead}</p>
							<form class="search" role="search">
								<label class="sr-only" for="deal-search">Tim deal</label>
								<div class="search-input">
									<span class="search-icon" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<circle cx="11" cy="11" r="7"></circle>
											<path d="M20 20l-3.5-3.5"></path>
										</svg>
									</span>
									<input id="deal-search" type="text" placeholder={searchPlaceholder} />
									<button class="btn" type="submit">Tim deal</button>
								</div>
							</form>
							<div class="hero-stats">
								{stats.map((stat) => (
									<div>
										<h3>{stat.value}</h3>
										<p>{stat.label}</p>
									</div>
								))}
							</div>
							<div class="hero-actions">
								<a class="btn" href="#deals">Xem deal hot</a>
								<a class="ghost" href="#how">Xem huong dan</a>
							</div>
						</div>
						<div class="hero-visual">
							<div class="hero-orb"></div>
							<div class="coupon-stack">
								{heroCards.map((card, index) => (
									<div
										class={`coupon-card${card.highlight ? ' highlight' : ''}${card.mini ? ' mini' : ''} reveal`}
										style={`--delay: ${0.1 + index * 0.15}s`}
									>
										{card.mini ? (
											<>
												<p>{card.title}</p>
												<strong>{card.meta}</strong>
												<span class="chip">{card.tag}</span>
											</>
										) : (
											<>
												<div class="coupon-brand">
													<span class="brand-dot"></span>
													<p>{card.brand}</p>
												</div>
												<h4>{card.title}</h4>
												<p class="coupon-meta">{card.meta}</p>
												<div class="coupon-footer">
													<span class={card.highlight ? 'tag alt' : 'tag'}>{card.tag}</span>
													<button class="code">{card.code}</button>
												</div>
											</>
										)}
									</div>
								))}
							</div>
						</div>
					</div>
				</section>

				<section class="section" id="categories" aria-labelledby="cat-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Danh muc pho bien</p>
								<h2 id="cat-title">De dang tim deal theo nhu cau</h2>
							</div>
							<a class="ghost" href="#all-categories">Xem tat ca</a>
						</div>
						<div class="grid categories-grid">
							{categories.map((category, index) => (
								<article class="category-card reveal" style={`--delay: ${0.1 + index * 0.1}s`}>
									<h3>{category.name}</h3>
									<p>{category.summary}</p>
									<p>{category.count}</p>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="section alt" id="deals" aria-labelledby="deals-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Deal noi bat</p>
								<h2 id="deals-title">Uu dai duoc san trong 24h</h2>
							</div>
							<div class="chip-row">
								<span class="chip">Tat ca</span>
								<span class="chip">Hoan tien</span>
								<span class="chip">Mien phi van chuyen</span>
								<span class="chip">Flash sale</span>
							</div>
						</div>
						<div class="grid deals-grid">
							{deals.map((deal, index) => (
								<article class="deal-card reveal" style={`--delay: ${0.1 + index * 0.1}s`}>
									<div class="deal-header">
										<span class="store-badge">{getBadge(deal.provider)}</span>
										<div>
											<h3>{deal.provider}</h3>
											<p>{deal.category}</p>
										</div>
									</div>
									<p class="deal-title">{deal.title}</p>
									<p class="deal-desc">{deal.description}</p>
									<div class="deal-meta">
										<span class={deal.tag === 'Hot' ? 'tag alt' : 'tag'}>{deal.tag}</span>
										<span class="muted">{deal.meta}</span>
									</div>
									<div class="deal-footer">
										<button class="code">{deal.code}</button>
										<a class="text-link" href="#">Xem chi tiet</a>
									</div>
								</article>
							))}
						</div>
					</div>
				</section>

				<section class="section" id="stores" aria-labelledby="stores-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Thuong hieu noi bat</p>
								<h2 id="stores-title">Cua hang duoc san nhieu nhat</h2>
							</div>
							<a class="ghost" href="#all-stores">Xem them cua hang</a>
						</div>
						<div class="stores-row">
							{stores.map((store) => (
								<div class="store-pill">{store}</div>
							))}
						</div>
					</div>
				</section>

				<section class="section steps" id="how" aria-labelledby="how-title">
					<div class="container">
						<div class="section-head">
							<div>
								<p class="eyebrow">Cach hoat dong</p>
								<h2 id="how-title">Nhan ma giam gia trong 3 buoc</h2>
							</div>
						</div>
						<div class="grid steps-grid">
							{steps.map((step, index) => (
								<div class="step-card reveal" style={`--delay: ${0.1 + index * 0.1}s`}>
									<span class="step">{`0${index + 1}`}</span>
									<h3>{step.title}</h3>
									<p>{step.description}</p>
								</div>
							))}
						</div>
					</div>
				</section>

				<section class="section app" id="app" aria-labelledby="app-title">
					<div class="container app-inner">
						<div>
							<p class="eyebrow">Ung dung di dong</p>
							<h2 id="app-title">Nhan thong bao deal moi moi ngay</h2>
							<p class="lead">
								Luu deal, theo doi cua hang va nhan thong bao flash sale theo khu vuc.
							</p>
							<div class="app-actions">
								<a class="btn" href="#">Tai tren App Store</a>
								<a class="ghost" href="#">Tai tren Google Play</a>
							</div>
						</div>
						<div class="app-card">
							<div class="app-screen">
								<div class="screen-header">
									<span></span>
									<span></span>
									<span></span>
								</div>
								<div class="screen-body">
									<h4>Deal gan ban</h4>
									<div class="screen-item"></div>
									<div class="screen-item"></div>
									<div class="screen-item"></div>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="section newsletter" id="blog" aria-labelledby="news-title">
					<div class="container newsletter-inner">
						<div>
							<p class="eyebrow">Ban tin Deala</p>
							<h2 id="news-title">{newsletterTitle}</h2>
							<p class="lead">{newsletterLead}</p>
						</div>
						<form class="newsletter-form">
							<label class="sr-only" for="newsletter-email">Email</label>
							<input id="newsletter-email" type="email" placeholder="Nhap email cua ban" />
							<button class="btn" type="submit">Dang ky</button>
						</form>
					</div>
				</section>
			</main>

			<footer class="site-footer" id="support">
				<div class="container footer-grid">
					<div>
						<div class="logo footer-logo">
							<span class="logo-mark">D</span>
							<span>Deala</span>
							<span class="logo-plus">+</span>
						</div>
						<p>Kenh san deal va ma giam gia thong minh cho nguoi Viet.</p>
					</div>
					<div>
						<h4>Ve Deala</h4>
						<a href="#">Gioi thieu</a>
						<a href="#">Doi tac</a>
						<a href="#">Tuyen dung</a>
					</div>
					<div>
						<h4>Ho tro</h4>
						<a href="#">Trung tam tro giup</a>
						<a href="#">Dieu khoan</a>
						<a href="#">Bao mat</a>
					</div>
					<div>
						<h4>Theo doi</h4>
						<a href="#">Facebook</a>
						<a href="#">Instagram</a>
						<a href="#">TikTok</a>
					</div>
				</div>
				<div class="footer-bottom">
					<p>&copy; 2026 Deala. All rights reserved.</p>
					<div class="footer-badges">
						<span>SSL Secure</span>
						<span>Trusted Stores</span>
						<span>24/7 Support</span>
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Sora:wght@400;500;600;700&display=swap');

	:global(body.deala) {
		--ink: #0c1b2a;
		--muted: #5b6b7f;
		--brand: #f94e30;
		--brand-strong: #f94e30;
		--brand-soft: #ffd7cf;
		--accent: #1fc7a6;
		--accent-dark: #0f8f77;
		--card: #ffffff;
		--border: rgba(12, 27, 42, 0.08);
		--shadow: 0 24px 60px rgba(12, 27, 42, 0.18);
		font-family: 'Manrope', 'Segoe UI', sans-serif;
		background: radial-gradient(circle at 10% 10%, #fff4ee 0%, transparent 45%),
			radial-gradient(circle at 90% 0%, #e7fbf6 0%, transparent 40%),
			linear-gradient(180deg, #fff8f2 0%, #ffffff 60%, #f6f9ff 100%);
		color: var(--ink);
		margin: 0;
	}

	:global(body.deala) main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	:global(body.deala) h1,
	:global(body.deala) h2,
	:global(body.deala) h3,
	:global(body.deala) h4 {
		font-family: 'Sora', 'Segoe UI', sans-serif;
		color: var(--ink);
		margin: 0 0 0.8rem 0;
	}

	:global(body.deala) p {
		margin: 0;
		color: var(--muted);
	}

	:global(body.deala) a {
		color: inherit;
		text-decoration: none;
	}

	.page {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.container {
		width: min(1200px, calc(100% - 2.5rem));
		margin: 0 auto;
	}

	.skip-link {
		position: absolute;
		left: -999px;
		top: 0;
		padding: 0.6rem 1rem;
		background: #fff;
		color: var(--ink);
		border-radius: 999px;
		z-index: 50;
	}
	.skip-link:focus {
		left: 1rem;
		top: 1rem;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(16px);
		background: rgba(255, 255, 255, 0.85);
		border-bottom: 1px solid var(--border);
	}

	.topbar {
		background: linear-gradient(90deg, #0f1e2f, #1b2d42);
		color: #eaf2ff;
		font-size: 0.9rem;
	}

	.topbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.6rem 0;
	}

	.topbar p {
		color: #eaf2ff;
		font-weight: 500;
	}

	.topbar-actions {
		display: flex;
		gap: 0.8rem;
		align-items: center;
	}

	.nav {
		padding: 0.8rem 0;
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.2rem;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-family: 'Sora', 'Segoe UI', sans-serif;
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--ink);
	}

	.logo-mark {
		width: 32px;
		height: 32px;
		border-radius: 12px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--brand), var(--accent));
		color: white;
		font-weight: 700;
	}

	.logo-plus {
		color: var(--brand);
	}

	.nav-links {
		display: flex;
		gap: 1.2rem;
		font-weight: 500;
		color: var(--muted);
	}

	.nav-links a:hover {
		color: var(--ink);
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.ghost,
	.text-link {
		border: 1px solid transparent;
		padding: 0.5rem 1.1rem;
		border-radius: 999px;
		font-weight: 600;
		color: var(--muted);
		background: transparent;
		transition: all 0.2s ease;
	}

	.text-link {
		padding: 0.4rem 0.4rem;
	}

	.ghost:hover {
		border-color: var(--border);
		color: var(--ink);
		background: rgba(249, 78, 48, 0.08);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		border: none;
		padding: 0.65rem 1.5rem;
		border-radius: 999px;
		background: linear-gradient(135deg, var(--brand), var(--brand-strong));
		color: white;
		font-weight: 600;
		box-shadow: 0 12px 24px rgba(249, 78, 48, 0.25);
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 16px 30px rgba(249, 78, 48, 0.3);
	}

	.btn.small {
		padding: 0.4rem 1rem;
		font-size: 0.9rem;
		box-shadow: none;
	}

	.hero {
		padding: 4.5rem 0 3.5rem;
		position: relative;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 3rem;
		align-items: center;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--accent-dark);
	}

	.hero-copy h1 {
		font-size: clamp(2.4rem, 3vw + 1rem, 3.6rem);
		line-height: 1.1;
	}

	.lead {
		font-size: 1.05rem;
		margin-bottom: 1.5rem;
	}

	.search {
		margin: 1.6rem 0 2rem;
	}

	.search-input {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		background: white;
		border-radius: 999px;
		padding: 0.4rem 0.5rem 0.4rem 1rem;
		box-shadow: var(--shadow);
		border: 1px solid transparent;
	}

	.search-input input {
		flex: 1;
		border: none;
		outline: none;
		font-size: 1rem;
		color: var(--ink);
		background: transparent;
	}

	.search-icon {
		display: inline-flex;
		width: 22px;
		height: 22px;
		color: var(--muted);
	}

	.hero-stats {
		display: flex;
		gap: 1.8rem;
		flex-wrap: wrap;
		margin-bottom: 1.5rem;
	}

	.hero-stats h3 {
		margin: 0;
		font-size: 1.4rem;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.hero-visual {
		position: relative;
		display: grid;
		place-items: center;
	}

	.hero-orb {
		position: absolute;
		width: 320px;
		height: 320px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(249, 78, 48, 0.3) 0%, rgba(249, 78, 48, 0) 70%);
		filter: blur(1px);
		animation: float 6s ease-in-out infinite;
	}

	.coupon-stack {
		display: grid;
		gap: 1rem;
		z-index: 2;
	}

	.coupon-card {
		background: white;
		padding: 1.3rem 1.4rem;
		border-radius: 20px;
		box-shadow: var(--shadow);
		border: 1px dashed rgba(12, 27, 42, 0.2);
		max-width: 320px;
		position: relative;
	}

	.coupon-card::before,
	.coupon-card::after {
		content: '';
		position: absolute;
		width: 16px;
		height: 16px;
		background: #f5f7fb;
		border-radius: 50%;
		top: 50%;
		transform: translateY(-50%);
	}

	.coupon-card::before {
		left: -8px;
	}

	.coupon-card::after {
		right: -8px;
	}

	.coupon-card.highlight {
		background: linear-gradient(135deg, #fff0e6, #ffffff);
		border-style: solid;
	}

	.coupon-card.mini {
		text-align: center;
		font-size: 0.95rem;
	}

	.coupon-brand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		font-weight: 700;
		color: var(--muted);
	}

	.brand-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--accent);
	}

	.coupon-meta {
		font-size: 0.85rem;
	}

	.coupon-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 1rem;
	}

	.tag {
		background: rgba(31, 199, 166, 0.15);
		color: var(--accent-dark);
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.tag.alt {
		background: rgba(249, 78, 48, 0.15);
		color: var(--brand-strong);
	}

	.code {
		background: rgba(12, 27, 42, 0.06);
		border: 1px dashed rgba(12, 27, 42, 0.2);
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		font-weight: 600;
		color: var(--ink);
		cursor: pointer;
	}

	.chip {
		background: rgba(12, 27, 42, 0.06);
		color: var(--muted);
		padding: 0.3rem 0.8rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 600;
	}

	.section {
		padding: 3.5rem 0;
	}

	.section.alt {
		background: #f8fafc;
	}

	.section-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 2.2rem;
	}

	.grid {
		display: grid;
		gap: 1.5rem;
	}

	.categories-grid {
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
	}

	.category-card {
		background: white;
		border-radius: 20px;
		padding: 1.5rem;
		box-shadow: 0 18px 40px rgba(12, 27, 42, 0.08);
		border: 1px solid transparent;
		transition: transform 0.2s ease, border 0.2s ease;
	}

	.category-card:hover {
		transform: translateY(-6px);
		border-color: var(--border);
	}

	.deals-grid {
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	}

